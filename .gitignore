# =============================================================================
# Seatbelt Detector — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente virtual Python
# -----------------------------------------------------------------------------
env/
venv/
.venv/
.env/
__pypackages__/

# -----------------------------------------------------------------------------
# Cache Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# -----------------------------------------------------------------------------
# Modelos pre-treinados e pesos (binarios grandes)
# Os modelos treinados ficam em runs/ (tambem ignorado abaixo).
# Se quiser versionar um checkpoint especifico, use git-lfs ou salve fora.
# -----------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.engine
*.trt
*.pb
*.h5
*.ckpt

# -----------------------------------------------------------------------------
# Resultados de treinamento e inferencia (gerados automaticamente)
# -----------------------------------------------------------------------------
runs/

# -----------------------------------------------------------------------------
# Cache do dataset (gerado pelo Ultralytics na primeira execucao)
# -----------------------------------------------------------------------------
dataset/**/*.cache
dataset/_data_resolved.yaml

# -----------------------------------------------------------------------------
# Logs e artefatos de experimentos
# -----------------------------------------------------------------------------
*.log
*.csv
wandb/
mlruns/
lightning_logs/
.neptune/
.clearml/

# -----------------------------------------------------------------------------
# Jupyter Notebooks — checkpoints
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Distribuicao / build Python
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
site/

# -----------------------------------------------------------------------------
# Pytest / coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# Variaveis de ambiente e segredos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.yaml
credentials.json
